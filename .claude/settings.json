{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(jest *)",
      "Bash(rm test.txt)",
      "Read",
      "Glob",
      "Grep"
    ],
    "deny": [
      "Bash(git push --force *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'Bash executed'",
            "once": true
          }
        ]
      }
    ]
  },
  "cleanupPeriodDays": 30
}
